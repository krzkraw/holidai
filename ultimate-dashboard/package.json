{
  "name": "ultimate-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate:bookings && rsbuild dev --host 127.0.0.1",
    "build": "npm run generate:bookings && rsbuild build",
    "generate:bookings": "bun run scripts/generate-bookings-data.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rsbuild/core": "^1.6.6",
    "@rsbuild/plugin-react": "^1.4.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
